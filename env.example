# ─────────────────────────────────────────────────────────────
# Critic Pipeline — Environment Config
# Copy this file to .env and fill in your values
# Usage: cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
# Anthropic API key — used by Claude Vision (vision node)
# and Claude LLM (critic node)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Server (optional) ─────────────────────────────────────────
# Port for the UI server (default: 7474)
PORT=7474

# ── Pipeline Tuning (optional) ────────────────────────────────
# Max frames sent to Claude Vision per video (default: 8)
# Lower = faster + cheaper, Higher = more thorough
MAX_FRAMES=8

# Score threshold below which verdict becomes "reject" (default: 50)
REJECT_THRESHOLD=50

# Score threshold below which verdict becomes "refine" (default: 80)
REFINE_THRESHOLD=80

# Whisper model size: tiny | base | small | medium | large (default: base)
# Larger = more accurate, slower. "base" is fine for hackathon.
WHISPER_MODEL=base

# Silence detection threshold in dB (default: -35)
# More negative = only flag very quiet parts
SILENCE_THRESHOLD_DB=-35

# Minimum silence duration in seconds to flag as dead air (default: 2.0)
MIN_SILENCE_DURATION=2.0
